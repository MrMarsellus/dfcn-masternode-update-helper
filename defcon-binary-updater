#!/usr/bin/env bash

set -u
set -o pipefail

SCRIPT_VERSION="0.1.0"

# --- Auto update defaults ---
AUTO_DOWNLOAD_URL="https://www.dfcn.io/wp-content/uploads/downloads/defcon-linux.tgz"
AUTO_DOWNLOAD_SHA256="89dd4d7f3536b2c581bee1bcad9d4ec6de874cc789bff31e7d55aee54799a3c2"

# --- Default paths ---
DEFAULT_DEFCON_USER="defcon"
DEFAULT_DEFCON_HOME="/home/defcon"
DEFAULT_DATA_DIR="/home/defcon/.defcon"
DEFAULT_CONF_FILE="/home/defcon/.defcon/defcon.conf"
DEFAULT_CLI="/usr/local/bin/defcon-cli"
DEFAULT_DAEMON="/usr/local/bin/defcond"
DEFAULT_SERVICE="defcond"
DEFAULT_INSTALL_DIR="/usr/local/bin"
BACKUP_BASE_DIR="/var/backups/defcon-binary-updater"
WORK_DIR="/tmp/defcon-binary-updater"
LOG_DIR="/var/log/defcon-binary-updater"

SERVICE_WAS_DISABLED=0
SERVICE_WAS_MASKED=0
SELECTED_ACTION=""
UPDATE_SOURCE_MODE=""
SELECTED_SOURCE=""
SELECTED_SOURCE_TYPE=""
SELECTED_ARCHIVE_PATH=""
SELECTED_SHA256=""
CURRENT_VERSION="unknown"
TARGET_VERSION="unknown"
TARGET_VERSION_FROM_FILENAME="unknown"
LATEST_BACKUP_DIR=""
LOG_FILE=""
ROLLBACK_SOURCE="unknown"
ROLLBACK_ACTION="unknown"
KEEP_COUNT=""
DELETE_OLDER_THAN_DAYS=""
DRY_RUN=0
ENABLE_AUTO_ROLLBACK=1
MIN_FREE_MB_DOWNLOAD=200
MIN_FREE_MB_BACKUP=100
EXPECTED_BINARY_COUNT_MIN=2
EXPECTED_BINARY_NAMES="defcond defcon-cli"

BACKUP_DIRS=()
BACKUP_DISPLAY_LINES=()
BACKUP_VERSIONS=()
BACKUP_TIMESTAMPS=()
BACKUP_SIZES=()
BACKUP_SOURCES=()
BACKUP_ACTIONS=()

print_line() {
  echo "------------------------------------------------------------"
}

timestamp_now() {
  date '+%Y-%m-%d %H:%M:%S'
}

log_plain() {
  local level="$1"
  shift
  local msg="$*"
  printf '[%s] [%s] %s\n' "$(timestamp_now)" "$level" "$msg"
}

info() {
  log_plain "INFO" "$*"
}

warn() {
  log_plain "WARN" "$*"
}

error() {
  log_plain "ERROR" "$*"
}

success() {
  log_plain "OK" "$*"
}

ask_yes_no() {
  local prompt="$1"
  local answer
  read -r -p "$prompt [y/N]: " answer
  case "$answer" in
    y|Y|yes|YES) return 0 ;;
    *) return 1 ;;
  esac
}

trim() {
  local s="${1:-}"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

is_number() {
  [[ "${1:-}" =~ ^[0-9]+$ ]]
}

run_cli() {
  "${DEFAULT_CLI}" -datadir="${DEFAULT_DATA_DIR}" -conf="${DEFAULT_CONF_FILE}" "$@"
}

run_cmd() {
  if [[ "${DRY_RUN}" -eq 1 ]]; then
    info "[DRY-RUN] $*"
    return 0
  fi
  "$@"
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)
        DRY_RUN=1
        ;;
      --no-auto-rollback)
        ENABLE_AUTO_ROLLBACK=0
        ;;
      *)
        warn "Unbekanntes Argument wird ignoriert: $1"
        ;;
    esac
    shift
  done
}

get_free_mb_for_path() {
  local path="$1"
  df -Pm "$path" 2>/dev/null | awk 'NR==2 {print $4}'
}

check_free_space_or_exit() {
  local path="$1"
  local required_mb="$2"
  local label="$3"
  local free_mb
  free_mb="$(get_free_mb_for_path "$path")"
  if ! [[ "$free_mb" =~ ^[0-9]+$ ]]; then
    error "Freier Speicher für ${label} konnte nicht ermittelt werden (${path})."
    exit 1
  fi
  info "Freier Speicher für ${label}: ${free_mb} MB (benötigt: mindestens ${required_mb} MB)"
  if (( free_mb < required_mb )); then
    error "Zu wenig freier Speicher für ${label}."
    exit 1
  fi
}

validate_archive_contents() {
  local count=0 name found
  info "Prüfe Archiv-Inhalt auf erwartete Binaries..."
  for name in ${EXPECTED_BINARY_NAMES}; do
    found="$(find "${WORK_DIR}/extract" -type f -name "$name" | head -n1 || true)"
    if [[ -n "$found" ]]; then
      success "Erwartete Datei gefunden: $name -> $found"
      count=$((count + 1))
    else
      error "Erwartete Datei fehlt im Archiv: $name"
      exit 1
    fi
  done
  if (( count < EXPECTED_BINARY_COUNT_MIN )); then
    error "Zu wenige erwartete Binary-Dateien im Archiv gefunden."
    exit 1
  fi
}

attempt_auto_rollback_after_failed_start() {
  if [[ "${ENABLE_AUTO_ROLLBACK}" -ne 1 ]]; then
    warn "Auto-Rollback ist deaktiviert."
    return 1
  fi
  if [[ -z "${LATEST_BACKUP_DIR}" || ! -d "${LATEST_BACKUP_DIR}" ]]; then
    error "Auto-Rollback nicht möglich, kein gültiges Backup-Verzeichnis vorhanden."
    return 1
  fi

  warn "Der Start nach dem Update ist fehlgeschlagen. Auto-Rollback wird versucht..."
  perform_rollback_install || return 1
  if systemctl list-unit-files | grep -q "^${DEFAULT_SERVICE}\.service"; then
    run_cmd systemctl daemon-reload >/dev/null 2>&1 || true
  fi
  if ! run_cmd systemctl start "${DEFAULT_SERVICE}" >/dev/null 2>&1; then
    error "Auto-Rollback konnte den Service nicht starten."
    return 1
  fi
  sleep 5
  if systemctl is-active --quiet "${DEFAULT_SERVICE}"; then
    success "Auto-Rollback erfolgreich. Der vorherige Stand läuft wieder."
    return 0
  fi
  error "Auto-Rollback konnte den Dienst nicht stabil starten."
  return 1
}

cleanup_workdir() {
  if [[ -d "${WORK_DIR}" ]]; then
    run_cmd rm -rf "${WORK_DIR}" >/dev/null 2>&1 || true
  fi
}

on_exit() {
  local exit_code=$?
  cleanup_workdir
  if [[ $exit_code -eq 0 ]]; then
    info "Temporäres Arbeitsverzeichnis bereinigt: ${WORK_DIR}"
  else
    warn "Script endet mit Exit-Code ${exit_code}. Temporäres Arbeitsverzeichnis wurde bereinigt: ${WORK_DIR}"
    if [[ -n "${LOG_FILE}" ]]; then
      warn "Siehe Logfile: ${LOG_FILE}"
    fi
  fi
}

setup_logging() {
  mkdir -p "${LOG_DIR}"
  LOG_FILE="${LOG_DIR}/defcon-binary-updater-$(date +%Y%m%d-%H%M%S).log"
  touch "${LOG_FILE}" || {
    echo "[ERROR] Konnte Logfile nicht anlegen: ${LOG_FILE}"
    exit 1
  }
  exec > >(tee -a "${LOG_FILE}") 2>&1
  info "Logfile aktiv: ${LOG_FILE}"
}

check_root() {
  if [ "$(id -u)" -ne 0 ]; then
    error "Bitte das Script als root ausführen."
    exit 1
  fi
}

check_conf_file() {
  if [ ! -f "${DEFAULT_CONF_FILE}" ]; then
    error "Config-Datei nicht gefunden: ${DEFAULT_CONF_FILE}"
    exit 1
  fi
}

check_binaries() {
  if [ ! -x "${DEFAULT_CLI}" ]; then
    error "defcon-cli nicht gefunden oder nicht ausführbar: ${DEFAULT_CLI}"
    exit 1
  fi

  if [ ! -x "${DEFAULT_DAEMON}" ]; then
    error "defcond nicht gefunden oder nicht ausführbar: ${DEFAULT_DAEMON}"
    exit 1
  fi

  local required
  for required in jq timeout grep awk sed tar sha256sum file pgrep pkill systemctl find sort head date cp mv chmod mkdir rm ls du basename readlink stat tail wc cut tr; do
    if ! command -v "$required" >/dev/null 2>&1; then
      error "Erforderliches Kommando fehlt: $required"
      exit 1
    fi
  done

  if ! command -v curl >/dev/null 2>&1 && ! command -v wget >/dev/null 2>&1; then
    error "Es wird curl oder wget benötigt."
    exit 1
  fi

  success "Erforderliche Binaries und Tools wurden gefunden."
}

prepare_runtime_dirs() {
  run_cmd mkdir -p "${BACKUP_BASE_DIR}" "${WORK_DIR}" "${LOG_DIR}"
}

show_intro() {
  print_line
  echo "DeFCoN Masternode Binary Updater v${SCRIPT_VERSION}"
  echo "Update-, Rollback- und Backup-Cleanup-Helfer für defcond / defcon-cli"
  print_line
}

show_defaults() {
  echo "Aktuelle Standardwerte:"
  echo "DEFCON user        : ${DEFAULT_DEFCON_USER}"
  echo "DEFCON home        : ${DEFAULT_DEFCON_HOME}"
  echo "Data directory     : ${DEFAULT_DATA_DIR}"
  echo "Config file        : ${DEFAULT_CONF_FILE}"
  echo "CLI binary         : ${DEFAULT_CLI}"
  echo "Daemon binary      : ${DEFAULT_DAEMON}"
  echo "Service name       : ${DEFAULT_SERVICE}"
  echo "Install dir        : ${DEFAULT_INSTALL_DIR}"
  echo "Backup base dir    : ${BACKUP_BASE_DIR}"
  echo "Work dir           : ${WORK_DIR}"
  echo "Log dir            : ${LOG_DIR}"
  echo "Auto download URL  : ${AUTO_DOWNLOAD_URL}"
  echo "Auto SHA256 gesetzt: $([[ -n "${AUTO_DOWNLOAD_SHA256}" ]] && echo yes || echo no)"
  print_line
}

human_size() {
  local bytes="${1:-0}"
  awk -v b="$bytes" 'function human(x){s="B KB MB GB TB PB"; split(s,a," "); i=1; while(x>=1024 && i<6){x/=1024;i++} printf((i==1?"%.0f %s":"%.2f %s"),x,a[i])} BEGIN{human(b)}'
}

read_backup_info_value() {
  local file="$1"
  local key="$2"
  if [[ ! -f "$file" ]]; then
    echo ""
    return 0
  fi
  grep -E "^${key}=" "$file" | head -n1 | cut -d= -f2- || true
}

get_binary_version() {
  local bin="$1"
  if [ ! -x "$bin" ]; then
    echo "unavailable"
    return 0
  fi

  local out
  out="$($bin --version 2>/dev/null | head -n 1 || true)"
  if [ -n "$out" ]; then
    echo "$out"
  else
    echo "unknown"
  fi
}

version_from_filename() {
  local src="$1"
  local base cleaned ver
  base="$(basename "$src")"
  cleaned="$base"
  cleaned="${cleaned%.tar.gz}"
  cleaned="${cleaned%.tgz}"
  cleaned="${cleaned%.tar}"
  cleaned="${cleaned%.zip}"

  ver="$(echo "$cleaned" | grep -Eo '([0-9]+\.)+[0-9]+([.-](rc|beta|alpha)[0-9]*)?' | head -n1 || true)"
  if [[ -n "$ver" ]]; then
    echo "$ver"
    return 0
  fi

  ver="$(echo "$cleaned" | sed -E 's/[_-]+/ /g' | grep -Eo 'v?[0-9]+([[:space:]][0-9]+)+' | head -n1 | tr ' ' '.' | sed 's/^v//' || true)"
  if [[ -n "$ver" ]]; then
    echo "$ver"
    return 0
  fi

  echo "unknown"
}

get_current_version() {
  CURRENT_VERSION="$(get_binary_version "${DEFAULT_DAEMON}")"
}

check_service_and_process() {
  print_line
  info "Prüfe Service und Daemon-Prozess..."

  if systemctl list-unit-files | grep -q "^${DEFAULT_SERVICE}\\.service"; then
    echo "Service-Datei      : gefunden (${DEFAULT_SERVICE}.service)"
    if systemctl is-active --quiet "${DEFAULT_SERVICE}"; then
      echo "Service-Status     : active"
    else
      echo "Service-Status     : not active"
    fi
    if systemctl is-enabled "${DEFAULT_SERVICE}" >/dev/null 2>&1; then
      echo "Service aktiviert  : yes"
    else
      echo "Service aktiviert  : no"
    fi
  else
    warn "Service-Datei ${DEFAULT_SERVICE}.service wurde nicht gefunden."
  fi

  if pgrep -f "${DEFAULT_DAEMON}" >/dev/null 2>&1; then
    local proc_line pid cmd bin
    proc_line="$(pgrep -af "${DEFAULT_DAEMON}" | head -n1)"
    pid="${proc_line%% *}"
    cmd="${proc_line#* }"
    bin="${cmd%% *}"
    echo "Daemon-Prozess     : running"
    echo "Daemon-PID         : ${pid}"
    echo "Daemon-Binary      : ${bin}"
  else
    echo "Daemon-Prozess     : not running"
  fi

  print_line
}

show_local_status() {
  print_line
  info "Prüfe lokalen Node-Status..."
  local blockcount="unknown"
  blockcount="$(run_cli getblockcount 2>/dev/null || echo "unavailable")"
  echo "Lokale Blockhöhe   : ${blockcount}"
  echo
  echo "Masternode status:"
  run_cli masternode status 2>/dev/null || warn "masternode status konnte nicht gelesen werden."
  echo
  echo "Masternode sync status:"
  run_cli mnsync status 2>/dev/null || warn "mnsync status konnte nicht gelesen werden."
  print_line
}

ensure_daemon_running() {
  print_line
  info "Prüfe, ob der Daemon bereits läuft..."

  local rpc_ok=1
  local service_active=1
  local proc_ok=1
  local service_exists=1

  if timeout 5 "${DEFAULT_CLI}" -datadir="${DEFAULT_DATA_DIR}" -conf="${DEFAULT_CONF_FILE}" getblockcount >/dev/null 2>&1; then
    rpc_ok=0
  fi

  if systemctl list-unit-files | grep -q "^${DEFAULT_SERVICE}\.service"; then
    service_exists=0
    if systemctl is-active --quiet "${DEFAULT_SERVICE}"; then
      service_active=0
    fi
  fi

  if pgrep -f "${DEFAULT_DAEMON}" >/dev/null 2>&1; then
    proc_ok=0
  fi

  if [ "${rpc_ok}" -eq 0 ]; then
    success "Daemon läuft bereits und RPC antwortet."
    check_service_and_process
    return 0
  fi

  print_line
  echo "Start-Prüfung:"
  echo " - Service-Datei gefunden : $([[ ${service_exists} -eq 0 ]] && echo yes || echo no)"
  echo " - Service aktiv          : $([[ ${service_active} -eq 0 ]] && echo yes || echo no)"
  echo " - Daemon-Prozess         : $([[ ${proc_ok} -eq 0 ]] && echo yes || echo no)"
  echo " - RPC antwortet          : no"
  print_line

  warn "Daemon scheint aktuell nicht vollständig gesund zu laufen oder RPC antwortet nicht."
}

verify_daemon_stopped() {
  local rpc_dead=1
  local proc_dead=1
  local service_inactive=1

  if ! pgrep -f "${DEFAULT_DAEMON}" >/dev/null 2>&1; then
    proc_dead=0
  fi

  if systemctl list-unit-files | grep -q "^${DEFAULT_SERVICE}\\.service"; then
    if ! systemctl is-active --quiet "${DEFAULT_SERVICE}"; then
      service_inactive=0
    fi
  else
    service_inactive=0
  fi

  if ! timeout 5 "${DEFAULT_CLI}" -datadir="${DEFAULT_DATA_DIR}" -conf="${DEFAULT_CONF_FILE}" getblockcount >/dev/null 2>&1; then
    rpc_dead=0
  fi

  print_line
  echo "Stop-Verifikation:"
  echo " - Prozess gestoppt : $([[ ${proc_dead} -eq 0 ]] && echo yes || echo no)"
  echo " - Service inaktiv  : $([[ ${service_inactive} -eq 0 ]] && echo yes || echo no)"
  echo " - RPC unerreichbar : $([[ ${rpc_dead} -eq 0 ]] && echo yes || echo no)"
  print_line

  if [[ ${proc_dead} -eq 0 && ${service_inactive} -eq 0 && ${rpc_dead} -eq 0 ]]; then
    return 0
  fi
  return 1
}

show_stop_summary() {
  print_line
  echo "Shutdown-Zusammenfassung"
  echo "------------------------"

  if systemctl list-unit-files | grep -q "^${DEFAULT_SERVICE}\\.service"; then
    if systemctl is-active --quiet "${DEFAULT_SERVICE}"; then
      echo "Service state : active"
    else
      echo "Service state : inactive"
    fi

    if systemctl is-enabled "${DEFAULT_SERVICE}" >/dev/null 2>&1; then
      echo "Service boot  : enabled"
    else
      echo "Service boot  : disabled or masked"
    fi
  else
    echo "Service state : service file not found"
  fi

  if pgrep -af "${DEFAULT_DAEMON}" >/dev/null 2>&1; then
    echo "Process state : running"
    pgrep -af "${DEFAULT_DAEMON}"
  else
    echo "Process state : not running"
  fi

  if timeout 5 "${DEFAULT_CLI}" -datadir="${DEFAULT_DATA_DIR}" -conf="${DEFAULT_CONF_FILE}" getblockcount >/dev/null 2>&1; then
    echo "RPC state     : responding"
  else
    echo "RPC state     : not responding"
  fi

  print_line
}

stop_daemon_cautious() {
  print_line
  warn "Der nächste Schritt kann Daemon und Service stoppen."
  warn "Das ist für Update oder Rollback erforderlich."

  if ! ask_yes_no "Möchtest du jetzt versuchen, den Masternode-Daemon zu stoppen?"; then
    warn "Stop-Schritt wurde vom Benutzer übersprungen."
    return 0
  fi

  info "Versuche zuerst systemctl stop..."
  systemctl stop "${DEFAULT_SERVICE}" >/dev/null 2>&1 || warn "systemctl stop war nicht erfolgreich."
  sleep 8
  verify_daemon_stopped && { success "Daemon wurde bereits sauber gestoppt."; return 0; }

  if ask_yes_no "Möchtest du den Service vorübergehend deaktivieren, um Auto-Restarts zu verhindern?"; then
    info "Versuche systemctl disable..."
    if systemctl disable "${DEFAULT_SERVICE}" >/dev/null 2>&1; then
      SERVICE_WAS_DISABLED=1
      success "Service wurde vorübergehend deaktiviert."
    else
      warn "systemctl disable war nicht erfolgreich."
    fi
    sleep 3
    verify_daemon_stopped && { success "Daemon wurde nach disable als gestoppt bestätigt."; return 0; }
  fi

  if pgrep -f "${DEFAULT_DAEMON}" >/dev/null 2>&1; then
    info "Versuche RPC stop..."
    run_cli stop >/dev/null 2>&1 || warn "RPC stop war nicht erfolgreich."
    sleep 10
    verify_daemon_stopped && { success "Daemon wurde nach RPC stop als gestoppt bestätigt."; return 0; }
  fi

  if pgrep -f "${DEFAULT_DAEMON}" >/dev/null 2>&1; then
    warn "Daemon läuft nach systemctl stop und RPC stop noch immer."
    if ask_yes_no "Möchtest du ein normales kill auf verbleibende Daemon-Prozesse versuchen?"; then
      pkill -f "${DEFAULT_DAEMON}" || warn "Normales kill war nicht erfolgreich."
      sleep 5
      verify_daemon_stopped && { success "Daemon wurde nach normalem kill als gestoppt bestätigt."; return 0; }
    fi
  fi

  if pgrep -f "${DEFAULT_DAEMON}" >/dev/null 2>&1; then
    warn "Daemon läuft nach normalem kill noch immer."
    if ask_yes_no "Möchtest du ein hartes kill -9 versuchen?"; then
      pkill -9 -f "${DEFAULT_DAEMON}" || warn "Hard kill war nicht erfolgreich."
      sleep 3
      verify_daemon_stopped && { success "Daemon wurde nach hard kill als gestoppt bestätigt."; return 0; }
    fi
  fi

  if pgrep -f "${DEFAULT_DAEMON}" >/dev/null 2>&1; then
    warn "Daemon läuft nach hard kill noch immer."
    if ask_yes_no "Möchtest du den Service temporär maskieren, um alle Restarts zu blockieren?"; then
      if systemctl mask "${DEFAULT_SERVICE}" >/dev/null 2>&1; then
        SERVICE_WAS_MASKED=1
        success "Service wurde temporär maskiert."
      else
        warn "systemctl mask war nicht erfolgreich."
      fi
      systemctl stop "${DEFAULT_SERVICE}" >/dev/null 2>&1 || true
      sleep 5
    fi
  fi

  show_stop_summary

  if verify_daemon_stopped; then
    success "Daemon und Service scheinen vollständig gestoppt zu sein."
    return 0
  fi

  error "Ein sicher gestoppter Zustand wurde NICHT bestätigt."
  warn "Update, Rollback oder Cleanup dürfen nicht fortgesetzt werden."
  return 1
}

restore_service_if_needed() {
  if [[ "${SERVICE_WAS_MASKED}" -eq 0 && "${SERVICE_WAS_DISABLED}" -eq 0 ]]; then
    return 0
  fi

  print_line
  info "Das Script hat den Service-Status zuvor verändert."
  if [[ "${SERVICE_WAS_MASKED}" -eq 1 ]]; then
    echo " - Service war temporär maskiert"
  fi
  if [[ "${SERVICE_WAS_DISABLED}" -eq 1 ]]; then
    echo " - Service war temporär deaktiviert"
  fi
  print_line

  if ! ask_yes_no "Möchtest du den Service-Zustand jetzt wiederherstellen und den Service starten?"; then
    warn "Service-Wiederherstellung wurde übersprungen."
    warn "Falls nötig später manuell: systemctl unmask/enable/start ${DEFAULT_SERVICE}"
    return 0
  fi

  if [[ "${SERVICE_WAS_MASKED}" -eq 1 ]]; then
    info "Versuche systemctl unmask ${DEFAULT_SERVICE}..."
    if systemctl unmask "${DEFAULT_SERVICE}" >/dev/null 2>&1; then
      success "Service wurde entmaskiert."
    else
      error "systemctl unmask war nicht erfolgreich."
    fi
    sleep 2
  fi

  if [[ "${SERVICE_WAS_DISABLED}" -eq 1 ]]; then
    info "Versuche systemctl enable ${DEFAULT_SERVICE}..."
    if systemctl enable "${DEFAULT_SERVICE}" >/dev/null 2>&1; then
      success "Service wurde aktiviert."
    else
      error "systemctl enable war nicht erfolgreich."
    fi
    sleep 2
  fi

  info "Versuche systemctl start ${DEFAULT_SERVICE}..."
  if ! systemctl start "${DEFAULT_SERVICE}" >/dev/null 2>&1; then
    error "systemctl start war nicht erfolgreich."
    echo "Prüfe: systemctl status ${DEFAULT_SERVICE}"
    echo "   und: journalctl -u ${DEFAULT_SERVICE} -n 50"
  else
    sleep 5
    if systemctl is-active --quiet "${DEFAULT_SERVICE}"; then
      success "Daemon scheint nach Service-Wiederherstellung zu laufen."
    else
      warn "Daemon scheint nach Service-Wiederherstellung nicht zu laufen."
    fi
  fi

  check_service_and_process
}

start_daemon_cautious() {
  print_line
  warn "Das Script kann jetzt versuchen, den Daemon wieder zu starten."

  if ! ask_yes_no "Möchtest du den Daemon jetzt starten?"; then
    warn "Start-Schritt wurde übersprungen."
    return 0
  fi

  info "Stelle sicher, dass keine manuellen ${DEFAULT_DAEMON}-Prozesse laufen..."
  pkill -f "${DEFAULT_DAEMON}" >/dev/null 2>&1 || true
  sleep 2

  info "Versuche systemctl start ${DEFAULT_SERVICE}..."
  if ! systemctl start "${DEFAULT_SERVICE}" >/dev/null 2>&1; then
    error "systemctl start war nicht erfolgreich."
    echo "Prüfe: systemctl status ${DEFAULT_SERVICE}"
    echo "   und: journalctl -u ${DEFAULT_SERVICE} -n 50"
    return 1
  fi

  sleep 5

  if systemctl is-active --quiet "${DEFAULT_SERVICE}"; then
    success "Daemon scheint via systemd zu laufen."
    return 0
  else
    error "Daemon scheint nach systemd start nicht zu laufen."
    echo "Prüfe: systemctl status ${DEFAULT_SERVICE}"
    echo "   und: journalctl -u ${DEFAULT_SERVICE} -n 50"
    return 1
  fi
}

show_post_start_checks() {
  print_line
  info "Prüfe, ob die Masternode nach dem Start sauber läuft..."
  check_service_and_process

  if timeout 10 run_cli getblockcount >/dev/null 2>&1; then
    success "RPC antwortet erfolgreich."
    echo "Blockhöhe         : $(run_cli getblockcount 2>/dev/null || echo unknown)"
  else
    error "RPC antwortet noch nicht."
  fi

  echo
  echo "getnetworkinfo:"
  run_cli getnetworkinfo 2>/dev/null || warn "getnetworkinfo fehlgeschlagen."
  echo
  echo "mnsync status:"
  run_cli mnsync status 2>/dev/null || warn "mnsync status fehlgeschlagen."
  echo
  echo "masternode status:"
  run_cli masternode status 2>/dev/null || warn "masternode status fehlgeschlagen."
  print_line
}

choose_action() {
  local choice
  print_line
  echo "Aktion wählen:"
  echo "  1) Binary-Update"
  echo "  2) Binary-Rollback"
  echo "  3) Vorhandene Backups bereinigen/löschen"
  print_line

  while true; do
    read -r -p "Enter 1, 2 oder 3: " choice
    case "$choice" in
      1)
        SELECTED_ACTION="update"
        return 0
        ;;
      2)
        SELECTED_ACTION="rollback"
        return 0
        ;;
      3)
        SELECTED_ACTION="cleanup"
        return 0
        ;;
      *)
        warn "Ungültige Auswahl. Bitte 1, 2 oder 3 eingeben."
        ;;
    esac
  done
}

choose_update_source_mode() {
  local choice
  print_line
  echo "Update-Quelle wählen:"
  echo "  1) Automatisches Update mit definierter Standard-URL"
  echo "  2) Download-URL oder lokaler Dateipfad manuell eingeben"
  print_line

  while true; do
    read -r -p "Enter 1 oder 2: " choice
    case "$choice" in
      1)
        UPDATE_SOURCE_MODE="auto"
        SELECTED_SOURCE_TYPE="url"
        SELECTED_SOURCE="${AUTO_DOWNLOAD_URL}"
        SELECTED_SHA256="${AUTO_DOWNLOAD_SHA256}"
        return 0
        ;;
      2)
        UPDATE_SOURCE_MODE="manual"
        return 0
        ;;
      *)
        warn "Ungültige Auswahl. Bitte 1 oder 2 eingeben."
        ;;
    esac
  done
}

prompt_manual_source() {
  local input
  print_line
  echo "Manuelle Quelle eingeben"
  echo "- URL (http/https) oder"
  echo "- lokaler Dateipfad zum Archiv"
  print_line

  while true; do
    read -r -p "Quelle: " input
    input="$(trim "${input:-}")"

    if [[ -z "$input" ]]; then
      warn "Bitte eine Quelle angeben."
      continue
    fi

    SELECTED_SOURCE="$input"
    if [[ "$input" =~ ^https?:// ]]; then
      SELECTED_SOURCE_TYPE="url"
    else
      SELECTED_SOURCE_TYPE="file"
    fi
    break
  done

  if ask_yes_no "Möchtest du im manuellen Modus optional eine SHA256-Prüfung verwenden?"; then
    read -r -p "SHA256 eingeben: " input
    input="$(trim "${input:-}")"
    if [[ -n "$input" ]]; then
      SELECTED_SHA256="$input"
      info "Manuelle SHA256-Prüfung wird verwendet."
    else
      warn "Keine SHA256 eingegeben. Es wird ohne SHA256-Prüfung fortgesetzt."
    fi
  else
    warn "Manueller Modus ohne SHA256-Prüfung ausgewählt."
  fi
}

validate_update_selection() {
  if [[ "${UPDATE_SOURCE_MODE}" == "auto" ]]; then
    if [[ -z "${AUTO_DOWNLOAD_URL}" ]]; then
      error "AUTO_DOWNLOAD_URL ist leer."
      exit 1
    fi
    if [[ -z "${AUTO_DOWNLOAD_SHA256}" ]]; then
      error "AUTO_DOWNLOAD_SHA256 ist leer. Für automatisches Update ist die SHA256 Pflicht."
      exit 1
    fi
  fi

  if [[ "${SELECTED_SOURCE_TYPE}" == "file" && ! -f "${SELECTED_SOURCE}" ]]; then
    error "Lokale Datei nicht gefunden: ${SELECTED_SOURCE}"
    exit 1
  fi
}

show_plan_summary() {
  print_line
  echo "Geplante Aktion:"
  echo "Aktion             : ${SELECTED_ACTION}"
  echo "Aktuelle Version   : ${CURRENT_VERSION}"
  if [[ "${SELECTED_ACTION}" == "update" ]]; then
    echo "Quellen-Modus      : ${UPDATE_SOURCE_MODE}"
    echo "Quellen-Typ        : ${SELECTED_SOURCE_TYPE}"
    echo "Quelle             : ${SELECTED_SOURCE}"
    echo "SHA256 aktiv       : $([[ -n "${SELECTED_SHA256}" ]] && echo yes || echo no)"
    echo "Version aus Name   : ${TARGET_VERSION_FROM_FILENAME}"
  elif [[ "${SELECTED_ACTION}" == "rollback" ]]; then
    echo "Rollback-Backup    : ${LATEST_BACKUP_DIR}"
    echo "Rollback-Quelle    : ${ROLLBACK_SOURCE}"
    echo "Rollback-Aktion    : ${ROLLBACK_ACTION}"
  fi
  echo "Installationsziel  : ${DEFAULT_INSTALL_DIR}"
  echo "Backup-Basis       : ${BACKUP_BASE_DIR}"
  echo "Service            : ${DEFAULT_SERVICE}"
  echo "Logfile            : ${LOG_FILE}"
  print_line
}

fetch_archive() {
  rm -rf "${WORK_DIR:?}/download" "${WORK_DIR:?}/extract"
  mkdir -p "${WORK_DIR}/download" "${WORK_DIR}/extract"
  SELECTED_ARCHIVE_PATH="${WORK_DIR}/download/$(basename "${SELECTED_SOURCE}")"

  if [[ "${SELECTED_SOURCE_TYPE}" == "url" ]]; then
    info "Lade Archiv herunter..."
    if command -v curl >/dev/null 2>&1; then
      if [[ "${DRY_RUN}" -eq 1 ]]; then info "[DRY-RUN] curl -L --fail --retry 3 -o ${SELECTED_ARCHIVE_PATH} ${SELECTED_SOURCE}"; else curl -L --fail --retry 3 -o "${SELECTED_ARCHIVE_PATH}" "${SELECTED_SOURCE}"; fi
    else
      if [[ "${DRY_RUN}" -eq 1 ]]; then info "[DRY-RUN] wget -O ${SELECTED_ARCHIVE_PATH} ${SELECTED_SOURCE}"; else wget -O "${SELECTED_ARCHIVE_PATH}" "${SELECTED_SOURCE}"; fi
    fi
  else
    info "Kopiere lokales Archiv in Arbeitsverzeichnis..."
    run_cmd cp -f "${SELECTED_SOURCE}" "${SELECTED_ARCHIVE_PATH}"
  fi

  if [[ ! -s "${SELECTED_ARCHIVE_PATH}" ]]; then
    error "Archiv wurde nicht korrekt bereitgestellt: ${SELECTED_ARCHIVE_PATH}"
    exit 1
  fi

  TARGET_VERSION_FROM_FILENAME="$(version_from_filename "${SELECTED_SOURCE}")"
  info "Version aus Archivnamen erkannt: ${TARGET_VERSION_FROM_FILENAME}"
  info "Download-/Dateiprüfung:"
  ls -lh "${SELECTED_ARCHIVE_PATH}"
  file "${SELECTED_ARCHIVE_PATH}" || true
}

verify_sha256_if_requested() {
  if [[ -z "${SELECTED_SHA256}" ]]; then
    warn "Keine SHA256-Prüfung aktiv."
    return 0
  fi

  local actual
  actual="$(sha256sum "${SELECTED_ARCHIVE_PATH}" | awk '{print $1}')"
  echo "Erwartete SHA256 : ${SELECTED_SHA256}"
  echo "Gefundene SHA256 : ${actual}"

  if [[ "${actual}" != "${SELECTED_SHA256}" ]]; then
    error "SHA256-Prüfung fehlgeschlagen. Abbruch."
    exit 1
  fi

  success "SHA256-Prüfung erfolgreich."
}

extract_archive() {
  info "Entpacke Archiv..."

  if [[ "${DRY_RUN}" -eq 1 ]]; then
    info "[DRY-RUN] Entpacken würde jetzt erfolgen: ${SELECTED_ARCHIVE_PATH}"
    export EXTRACTED_DAEMON="${WORK_DIR}/extract/defcond"
    export EXTRACTED_CLI="${WORK_DIR}/extract/defcon-cli"
    TARGET_VERSION="${TARGET_VERSION_FROM_FILENAME}"
    return 0
  fi

  case "${SELECTED_ARCHIVE_PATH}" in
    *.tar.gz|*.tgz)
      tar -xzf "${SELECTED_ARCHIVE_PATH}" -C "${WORK_DIR}/extract"
      ;;
    *.tar)
      tar -xf "${SELECTED_ARCHIVE_PATH}" -C "${WORK_DIR}/extract"
      ;;
    *)
      error "Unbekanntes Archivformat: ${SELECTED_ARCHIVE_PATH}"
      exit 1
      ;;
  esac

  local daemon_found cli_found
  daemon_found="$(find "${WORK_DIR}/extract" -type f -name 'defcond' | head -n 1 || true)"
  cli_found="$(find "${WORK_DIR}/extract" -type f -name 'defcon-cli' | head -n 1 || true)"

  if [[ -z "$daemon_found" || -z "$cli_found" ]]; then
    error "Im Archiv wurden defcond und/oder defcon-cli nicht gefunden."
    exit 1
  fi

  chmod +x "$daemon_found" "$cli_found"
  validate_archive_contents
  TARGET_VERSION="$(get_binary_version "$daemon_found")"
  if [[ "$TARGET_VERSION" == "unknown" || "$TARGET_VERSION" == "unavailable" ]] && [[ "$TARGET_VERSION_FROM_FILENAME" != "unknown" ]]; then
    TARGET_VERSION="${TARGET_VERSION_FROM_FILENAME}"
  fi
  export EXTRACTED_DAEMON="$daemon_found"
  export EXTRACTED_CLI="$cli_found"

  success "Archiv wurde erfolgreich entpackt."
  echo "Gefundene neue Version: ${TARGET_VERSION}"
}

create_binary_backup() {
  local ts backup_dir
  ts="$(date +%Y%m%d-%H%M%S)"
  backup_dir="${BACKUP_BASE_DIR}/${ts}"
  mkdir -p "${backup_dir}"

  check_free_space_or_exit "${BACKUP_BASE_DIR}" "${MIN_FREE_MB_BACKUP}" "Backup"
  run_cmd cp -a "${DEFAULT_DAEMON}" "${backup_dir}/defcond"
  run_cmd cp -a "${DEFAULT_CLI}" "${backup_dir}/defcon-cli"

  cat > "${backup_dir}/backup-info.txt" <<INFOEOF
Timestamp=${ts}
Action=${SELECTED_ACTION}
CurrentVersion=${CURRENT_VERSION}
SourceMode=${UPDATE_SOURCE_MODE}
Source=${SELECTED_SOURCE}
SourceType=${SELECTED_SOURCE_TYPE}
TargetVersion=${TARGET_VERSION}
TargetVersionFromFilename=${TARGET_VERSION_FROM_FILENAME}
DaemonPath=${DEFAULT_DAEMON}
CliPath=${DEFAULT_CLI}
LogFile=${LOG_FILE}
INFOEOF

  ln -sfn "${backup_dir}" "${BACKUP_BASE_DIR}/latest"
  LATEST_BACKUP_DIR="${backup_dir}"
  success "Backup der aktuellen Binaries erstellt: ${backup_dir}"
}

install_new_binaries() {
  info "Installiere neue Binaries..."
  run_cmd cp -f "${EXTRACTED_DAEMON}" "${DEFAULT_DAEMON}"
  run_cmd cp -f "${EXTRACTED_CLI}" "${DEFAULT_CLI}"
  run_cmd chmod 755 "${DEFAULT_DAEMON}" "${DEFAULT_CLI}"

  if [[ ! -x "${DEFAULT_DAEMON}" || ! -x "${DEFAULT_CLI}" ]]; then
    error "Neue Binaries wurden nicht korrekt installiert."
    exit 1
  fi

  success "Neue Binaries wurden erfolgreich installiert."
  echo "Installierte Version: $(get_binary_version "${DEFAULT_DAEMON}")"
}

load_backups() {
  BACKUP_DIRS=()
  BACKUP_DISPLAY_LINES=()
  BACKUP_VERSIONS=()
  BACKUP_TIMESTAMPS=()
  BACKUP_SIZES=()
  BACKUP_SOURCES=()
  BACKUP_ACTIONS=()

  while IFS= read -r dir; do
    [[ -n "$dir" ]] || continue
    BACKUP_DIRS+=("$dir")
  done < <(find "${BACKUP_BASE_DIR}" -mindepth 1 -maxdepth 1 -type d | sort)

  if [[ "${#BACKUP_DIRS[@]}" -eq 0 ]]; then
    warn "Keine Backup-Ordner gefunden in ${BACKUP_BASE_DIR}."
    return 1
  fi

  local dir info_file ts ver size_b size_h source action idx target_ver
  for idx in "${!BACKUP_DIRS[@]}"; do
    dir="${BACKUP_DIRS[$idx]}"
    info_file="${dir}/backup-info.txt"
    ts="$(basename "$dir")"
    ver="unknown"
    source="unknown"
    action="unknown"
    target_ver="unknown"

    if [[ -f "$info_file" ]]; then
      ts="$(read_backup_info_value "$info_file" "Timestamp")"
      [[ -n "$ts" ]] || ts="$(basename "$dir")"
      ver="$(read_backup_info_value "$info_file" "CurrentVersion")"
      [[ -n "$ver" ]] || ver="unknown"
      source="$(read_backup_info_value "$info_file" "Source")"
      [[ -n "$source" ]] || source="unknown"
      action="$(read_backup_info_value "$info_file" "Action")"
      [[ -n "$action" ]] || action="unknown"
      target_ver="$(read_backup_info_value "$info_file" "TargetVersion")"
      [[ -n "$target_ver" ]] || target_ver="unknown"
    fi

    size_b="$(du -sb "$dir" 2>/dev/null | awk '{print $1}')"
    size_h="$(human_size "$size_b")"
    BACKUP_TIMESTAMPS+=("$ts")
    BACKUP_VERSIONS+=("$ver")
    BACKUP_SIZES+=("$size_b")
    BACKUP_SOURCES+=("$source")
    BACKUP_ACTIONS+=("$action")
    BACKUP_DISPLAY_LINES+=("[$((idx + 1))] Datum/Zeit: ${ts} | Version: ${ver} | Ziel-Version: ${target_ver} | Aktion: ${action} | Größe: ${size_h} | Quelle: ${source}")
  done

  return 0
}

show_backup_list() {
  if ! load_backups; then
    return 1
  fi

  print_line
  echo "Vorhandene Backups:"
  local line
  for line in "${BACKUP_DISPLAY_LINES[@]}"; do
    echo "${line}"
  done
  print_line
  return 0
}

select_backup_for_rollback() {
  show_backup_list || exit 1

  local choice index selected
  while true; do
    read -r -p "Nummer des gewünschten Rollback-Backups: " choice
    if ! is_number "$choice"; then
      warn "Bitte eine gültige Nummer eingeben."
      continue
    fi
    index=$((choice - 1))
    if (( index < 0 || index >= ${#BACKUP_DIRS[@]} )); then
      warn "Nummer außerhalb des gültigen Bereichs."
      continue
    fi
    selected="${BACKUP_DIRS[$index]}"
    LATEST_BACKUP_DIR="$selected"
    ROLLBACK_SOURCE="${BACKUP_SOURCES[$index]}"
    ROLLBACK_ACTION="${BACKUP_ACTIONS[$index]}"
    print_line
    echo "Ausgewähltes Rollback-Backup:"
    echo "Pfad              : ${LATEST_BACKUP_DIR}"
    echo "Datum/Zeit        : ${BACKUP_TIMESTAMPS[$index]}"
    echo "Version           : ${BACKUP_VERSIONS[$index]}"
    echo "Größe             : $(human_size "${BACKUP_SIZES[$index]}")"
    echo "Quelle            : ${ROLLBACK_SOURCE}"
    echo "Aktion            : ${ROLLBACK_ACTION}"
    print_line
    return 0
  done
}

sum_selected_backup_bytes() {
  local total=0 dir bytes
  for dir in "$@"; do
    bytes="$(du -sb "$dir" 2>/dev/null | awk '{print $1}')"
    total=$((total + bytes))
  done
  echo "$total"
}

cleanup_selected_backups() {
  local dirs_to_delete=("$@")
  if [[ "${#dirs_to_delete[@]}" -eq 0 ]]; then
    warn "Keine Backups zum Löschen ausgewählt."
    return 0
  fi

  local total_bytes deleted_count=0 dir
  total_bytes="$(sum_selected_backup_bytes "${dirs_to_delete[@]}")"

  print_line
  echo "Folgende Backups werden gelöscht:"
  for dir in "${dirs_to_delete[@]}"; do
    echo " - ${dir}"
  done
  echo "Anzahl             : ${#dirs_to_delete[@]}"
  echo "Freizugebender Platz: $(human_size "$total_bytes")"
  print_line

  if ! ask_yes_no "Löschvorgang jetzt ausführen?"; then
    warn "Löschvorgang wurde abgebrochen."
    return 0
  fi

  for dir in "${dirs_to_delete[@]}"; do
    if rm -rf "$dir"; then
      success "Gelöscht: ${dir}"
      deleted_count=$((deleted_count + 1))
    else
      error "Konnte nicht löschen: ${dir}"
    fi
  done

  if [[ -L "${BACKUP_BASE_DIR}/latest" ]]; then
    local latest_target
    latest_target="$(readlink -f "${BACKUP_BASE_DIR}/latest" 2>/dev/null || true)"
    if [[ -n "$latest_target" && ! -d "$latest_target" ]]; then
      rm -f "${BACKUP_BASE_DIR}/latest" >/dev/null 2>&1 || true
      warn "Verwaister latest-Symlink wurde entfernt."
    fi
  fi

  print_line
  success "Backup-Bereinigung abgeschlossen."
  echo "Gelöschte Backups   : ${deleted_count}"
  echo "Freigemachter Platz : $(human_size "$total_bytes")"
  print_line
}

cleanup_all_backups() {
  show_backup_list || exit 1
  cleanup_selected_backups "${BACKUP_DIRS[@]}"
}

cleanup_keep_last_n_backups() {
  show_backup_list || exit 1

  while true; do
    read -r -p "Wie viele neueste Backups sollen behalten werden? " KEEP_COUNT
    KEEP_COUNT="$(trim "${KEEP_COUNT:-}")"
    if ! is_number "$KEEP_COUNT"; then
      warn "Bitte eine gültige Zahl eingeben."
      continue
    fi
    break
  done

  local total_count="${#BACKUP_DIRS[@]}"
  if (( KEEP_COUNT >= total_count )); then
    warn "Es gibt nur ${total_count} Backups. Es wird nichts gelöscht."
    return 0
  fi

  local delete_count=$((total_count - KEEP_COUNT))
  local dirs_to_delete=()
  local i
  for ((i=0; i<delete_count; i++)); do
    dirs_to_delete+=("${BACKUP_DIRS[$i]}")
  done

  cleanup_selected_backups "${dirs_to_delete[@]}"
}

cleanup_backups_older_than_days() {
  show_backup_list || exit 1

  while true; do
    read -r -p "Backups löschen, die älter sind als wie viele Tage? " DELETE_OLDER_THAN_DAYS
    DELETE_OLDER_THAN_DAYS="$(trim "${DELETE_OLDER_THAN_DAYS:-}")"
    if ! is_number "$DELETE_OLDER_THAN_DAYS"; then
      warn "Bitte eine gültige Zahl eingeben."
      continue
    fi
    break
  done

  local dirs_to_delete=()
  local dir
  while IFS= read -r dir; do
    [[ -n "$dir" ]] && dirs_to_delete+=("$dir")
  done < <(find "${BACKUP_BASE_DIR}" -mindepth 1 -maxdepth 1 -type d -mtime +"${DELETE_OLDER_THAN_DAYS}" | sort)

  if [[ "${#dirs_to_delete[@]}" -eq 0 ]]; then
    warn "Keine Backups gefunden, die älter als ${DELETE_OLDER_THAN_DAYS} Tage sind."
    return 0
  fi

  cleanup_selected_backups "${dirs_to_delete[@]}"
}

cleanup_menu() {
  local choice
  print_line
  echo "Backup-Bereinigung wählen:"
  echo "  1) Alle Backups löschen"
  echo "  2) Nur alte Backups löschen, letzte N behalten"
  echo "  3) Nur Backups löschen, die älter als X Tage sind"
  echo "  4) Nur Backups anzeigen"
  print_line

  while true; do
    read -r -p "Enter 1, 2, 3 oder 4: " choice
    case "$choice" in
      1)
        cleanup_all_backups
        return 0
        ;;
      2)
        cleanup_keep_last_n_backups
        return 0
        ;;
      3)
        cleanup_backups_older_than_days
        return 0
        ;;
      4)
        show_backup_list || true
        return 0
        ;;
      *)
        warn "Ungültige Auswahl. Bitte 1, 2, 3 oder 4 eingeben."
        ;;
    esac
  done
}

perform_rollback_install() {
  local rollback_daemon rollback_cli
  rollback_daemon="${LATEST_BACKUP_DIR}/defcond"
  rollback_cli="${LATEST_BACKUP_DIR}/defcon-cli"

  if [[ ! -x "${rollback_daemon}" || ! -x "${rollback_cli}" ]]; then
    error "Rollback-Binaries fehlen oder sind nicht ausführbar in ${LATEST_BACKUP_DIR}"
    exit 1
  fi

  TARGET_VERSION="$(get_binary_version "${rollback_daemon}")"
  info "Spiele Backup-Binaries zurück..."
  run_cmd cp -f "${rollback_daemon}" "${DEFAULT_DAEMON}"
  run_cmd cp -f "${rollback_cli}" "${DEFAULT_CLI}"
  run_cmd chmod 755 "${DEFAULT_DAEMON}" "${DEFAULT_CLI}"

  success "Rollback-Binaries wurden erfolgreich installiert."
  echo "Rollback-Version   : $(get_binary_version "${DEFAULT_DAEMON}")"
}

run_update() {
  choose_update_source_mode
  if [[ "${UPDATE_SOURCE_MODE}" == "manual" ]]; then
    prompt_manual_source
  fi
  validate_update_selection
  TARGET_VERSION_FROM_FILENAME="$(version_from_filename "${SELECTED_SOURCE}")"
  show_plan_summary

  if ! ask_yes_no "Soll mit dem Update fortgefahren werden?"; then
    warn "Update wurde vom Benutzer abgebrochen."
    exit 0
  fi

  check_free_space_or_exit "/tmp" "${MIN_FREE_MB_DOWNLOAD}" "Download/Entpacken"
  fetch_archive
  verify_sha256_if_requested
  extract_archive
  create_binary_backup

  if ! ask_yes_no "Soll der Daemon jetzt gestoppt und das Update installiert werden?"; then
    warn "Update wurde vor dem Installationsschritt abgebrochen."
    exit 0
  fi

  stop_daemon_cautious || exit 1
  verify_daemon_stopped || exit 1
  install_new_binaries

  if systemctl list-unit-files | grep -q "^${DEFAULT_SERVICE}\\.service"; then
    systemctl daemon-reload >/dev/null 2>&1 || true
  fi

  success "Update erfolgreich installiert."
  if ! start_daemon_cautious; then
    attempt_auto_rollback_after_failed_start || exit 1
  fi
  restore_service_if_needed
  show_post_start_checks
}

run_rollback() {
  select_backup_for_rollback
  show_plan_summary

  if ! ask_yes_no "Soll das Rollback mit dem ausgewählten Backup fortgesetzt werden?"; then
    warn "Rollback wurde vom Benutzer abgebrochen."
    exit 0
  fi

  stop_daemon_cautious || exit 1
  verify_daemon_stopped || exit 1
  perform_rollback_install

  if systemctl list-unit-files | grep -q "^${DEFAULT_SERVICE}\\.service"; then
    systemctl daemon-reload >/dev/null 2>&1 || true
  fi

  success "Rollback erfolgreich installiert."
  start_daemon_cautious || exit 1
  restore_service_if_needed
  show_post_start_checks
}

run_cleanup() {
  cleanup_menu
}

main() {
  parse_args "$@"
  trap on_exit EXIT
  check_root
  prepare_runtime_dirs
  setup_logging
  show_intro
  check_conf_file
  check_binaries
  show_defaults
  get_current_version
  ensure_daemon_running
  choose_action

  case "${SELECTED_ACTION}" in
    update)
      run_update
      ;;
    rollback)
      run_rollback
      ;;
    cleanup)
      run_cleanup
      ;;
    *)
      error "Unbekannte Aktion."
      exit 1
      ;;
  esac

  print_line
  echo "Script-Lauf abgeschlossen."
  echo "Bitte den Node weiter beobachten."
  echo "Logfile: ${LOG_FILE}"
  print_line
}

main "$@"
