#!/usr/bin/env bash

set -u
set -o pipefail

SCRIPT_VERSION="0.1.0"

# --- Auto update defaults ---
AUTO_DOWNLOAD_URL="https://www.dfcn.io/wp-content/uploads/downloads/defcon-linux.tgz"
AUTO_DOWNLOAD_SHA256="6ff3d32a5c717535b3210ae6f6b057f0f137aa1811748a80dbe0a1df9a4a563a"

# --- Default paths ---
DEFAULT_DEFCON_USER="defcon"
DEFAULT_DEFCON_HOME="/home/defcon"
DEFAULT_DATA_DIR="/home/defcon/.defcon"
DEFAULT_CONF_FILE="/home/defcon/.defcon/defcon.conf"
DEFAULT_CLI="/usr/local/bin/defcon-cli"
DEFAULT_DAEMON="/usr/local/bin/defcond"
DEFAULT_SERVICE="defcond"
DEFAULT_INSTALL_DIR="/usr/local/bin"
BACKUP_BASE_DIR="/var/backups/defcon-binary-updater"
WORK_DIR="/tmp/defcon-binary-updater"
LOG_DIR="/var/log/defcon-binary-updater"

SELECTED_ACTION=""
UPDATE_SOURCE_MODE=""
SELECTED_SOURCE=""
SELECTED_SOURCE_TYPE=""
SELECTED_ARCHIVE_PATH=""
SELECTED_SHA256=""
CURRENT_VERSION="unknown"
TARGET_VERSION="unknown"
TARGET_VERSION_FROM_FILENAME="unknown"
LATEST_BACKUP_DIR=""
LOG_FILE=""
ROLLBACK_SOURCE="unknown"
ROLLBACK_ACTION="unknown"
KEEP_COUNT=""
DELETE_OLDER_THAN_DAYS=""
DRY_RUN=0
ENABLE_AUTO_ROLLBACK=1
MIN_FREE_MB_DOWNLOAD=200
MIN_FREE_MB_BACKUP=100
EXPECTED_BINARY_COUNT_MIN=2
EXPECTED_BINARY_NAMES="defcond defcon-cli"

BACKUP_DIRS=()
BACKUP_DISPLAY_LINES=()
BACKUP_VERSIONS=()
BACKUP_TIMESTAMPS=()
BACKUP_SIZES=()
BACKUP_SOURCES=()
BACKUP_ACTIONS=()

print_line() {
  echo "------------------------------------------------------------"
}

timestamp_now() {
  date '+%Y-%m-%d %H:%M:%S'
}

log_plain() {
  local level="$1"
  shift
  local msg="$*"
  printf '[%s] [%s] %s\n' "$(timestamp_now)" "$level" "$msg"
}

info() {
  log_plain "INFO" "$*"
}

warn() {
  log_plain "WARN" "$*"
}

error() {
  log_plain "ERROR" "$*"
}

success() {
  log_plain "OK" "$*"
}

ask_yes_no() {
  local prompt="$1"
  local answer
  read -r -p "$prompt [y/N]: " answer
  case "$answer" in
    y|Y|yes|YES) return 0 ;;
    *) return 1 ;;
  esac
}

trim() {
  local s="${1:-}"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

is_number() {
  [[ "${1:-}" =~ ^[0-9]+$ ]]
}

run_cli() {
  "${DEFAULT_CLI}" -datadir="${DEFAULT_DATA_DIR}" -conf="${DEFAULT_CONF_FILE}" "$@"
}

run_cmd() {
  if [[ "${DRY_RUN}" -eq 1 ]]; then
    info "[DRY-RUN] $*"
    return 0
  fi
  "$@"
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)
        DRY_RUN=1
        ;;
      --no-auto-rollback)
        ENABLE_AUTO_ROLLBACK=0
        ;;
      *)
        warn "Unknown argument, ignoring: $1"
        ;;
    esac
    shift
  done
}

get_free_mb_for_path() {
  local path="$1"
  df -Pm "$path" 2>/dev/null | awk 'NR==2 {print $4}'
}

check_free_space_or_exit() {
  local path="$1"
  local required_mb="$2"
  local label="$3"
  local free_mb
  free_mb="$(get_free_mb_for_path "$path")"
  if ! [[ "$free_mb" =~ ^[0-9]+$ ]]; then
    error "Could not determine free space for ${label} at path: ${path}."
    exit 1
  fi
  info "Free space for ${label}: ${free_mb} MB (required: at least ${required_mb} MB)"
  if (( free_mb < required_mb )); then
    error "Not enough free space for ${label}."
    exit 1
  fi
}

validate_archive_contents() {
  local count=0 name found
  info "Validating archive contents for expected binaries..."
  for name in ${EXPECTED_BINARY_NAMES}; do
    found="$(find "${WORK_DIR}/extract" -type f -name "$name" | head -n1 || true)"
    if [[ -n "$found" ]]; then
      success "Expected file found: $name -> $found"
      count=$((count + 1))
    else
      error "Expected file missing in archive: $name"
      exit 1
    fi
  done
  if (( count < EXPECTED_BINARY_COUNT_MIN )); then
    error "Too few expected binary files found in archive."
    exit 1
  fi
}

attempt_auto_rollback_after_failed_start() {
  if [[ "${ENABLE_AUTO_ROLLBACK}" -ne 1 ]]; then
    warn "Auto rollback is disabled."
    return 1
  fi
  if [[ -z "${LATEST_BACKUP_DIR}" || ! -d "${LATEST_BACKUP_DIR}" ]]; then
    error "Auto rollback not possible, no valid backup directory set."
    return 1
  fi

  warn "Start after update failed. Attempting automatic rollback..."
  perform_rollback_install || return 1
  if systemctl status "${DEFAULT_SERVICE}.service" >/dev/null 2>&1; then
    run_cmd systemctl daemon-reload >/dev/null 2>&1 || true
  fi
  if ! run_cmd systemctl start "${DEFAULT_SERVICE}" >/dev/null 2>&1; then
    error "Auto rollback could not start the service."
    return 1
  fi
  sleep 5
  if systemctl is-active --quiet "${DEFAULT_SERVICE}"; then
    success "Auto rollback completed, previous version is running again."
    return 0
  fi
  error "Auto rollback could not bring the service into a stable running state."
  return 1
}

cleanup_workdir() {
  if [[ -d "${WORK_DIR}" ]]; then
    run_cmd rm -rf "${WORK_DIR}" >/dev/null 2>&1 || true
  fi
}

on_exit() {
  local exit_code=$?
  cleanup_workdir
  if [[ $exit_code -eq 0 ]]; then
    info "Temporary work directory cleaned up: ${WORK_DIR}"
  else
    warn "Script exited with code ${exit_code}. Temporary work directory was cleaned: ${WORK_DIR}"
    if [[ -n "${LOG_FILE}" ]]; then
      warn "See log file for details: ${LOG_FILE}"
    fi
  fi
}

setup_logging() {
  mkdir -p "${LOG_DIR}" || {
    echo "[ERROR] Could not create log directory: ${LOG_DIR}"
    exit 1
  }
  LOG_FILE="${LOG_DIR}/defcon-binary-updater-$(date +%Y%m%d-%H%M%S).log"
  touch "${LOG_FILE}" || {
    echo "[ERROR] Could not create log file: ${LOG_FILE}"
    exit 1
  }
  exec > >(tee -a "${LOG_FILE}") 2>&1
  info "Logging enabled: ${LOG_FILE}"
}

check_root() {
  if [ "$(id -u)" -ne 0 ]; then
    error "Please run this script as root."
    exit 1
  fi
}

check_conf_file() {
  if [ ! -f "${DEFAULT_CONF_FILE}" ]; then
    error "Config file not found: ${DEFAULT_CONF_FILE}"
    exit 1
  fi
}

prepare_directories() {
  mkdir -p "${BACKUP_BASE_DIR}" || {
    error "Could not create backup directory: ${BACKUP_BASE_DIR}"
    exit 1
  }

  mkdir -p "${WORK_DIR}" || {
    error "Could not create work directory: ${WORK_DIR}"
    exit 1
  }

  mkdir -p "${LOG_DIR}" || {
    error "Could not create log directory: ${LOG_DIR}"
    exit 1
  }

  success "Required directories are ready."
}

check_binaries() {
  if [ ! -x "${DEFAULT_CLI}" ]; then
    error "defcon-cli not found or not executable at: ${DEFAULT_CLI}"
    exit 1
  fi

  if [ ! -x "${DEFAULT_DAEMON}" ]; then
    error "defcond not found or not executable at: ${DEFAULT_DAEMON}"
    exit 1
  fi

  local required
  for required in jq timeout grep awk sed tar sha256sum file pgrep pkill systemctl find sort head date cp mv chmod mkdir rm ls du basename readlink stat tail wc cut tr; do
    if ! command -v "$required" >/dev/null 2>&1; then
      error "Required command is missing: $required"
      exit 1
    fi
  done

  if ! command -v curl >/dev/null 2>&1 && ! command -v wget >/dev/null 2>&1; then
    error "Either curl or wget is required but neither was found."
    exit 1
  fi

  success "Required binaries and tools were found."
}

show_intro() {
  print_line
  echo "DeFCoN Masternode Binary Updater v${SCRIPT_VERSION}"
  echo "Helper for update, rollback and backup cleanup of defcond / defcon-cli"
  print_line
}

show_defaults() {
  echo "Current defaults:"
  echo "DEFCON user        : ${DEFAULT_DEFCON_USER}"
  echo "DEFCON home        : ${DEFAULT_DEFCON_HOME}"
  echo "Data directory     : ${DEFAULT_DATA_DIR}"
  echo "Config file        : ${DEFAULT_CONF_FILE}"
  echo "CLI binary         : ${DEFAULT_CLI}"
  echo "Daemon binary      : ${DEFAULT_DAEMON}"
  echo "Service name       : ${DEFAULT_SERVICE}"
  echo "Install dir        : ${DEFAULT_INSTALL_DIR}"
  echo "Backup base dir    : ${BACKUP_BASE_DIR}"
  echo "Work dir           : ${WORK_DIR}"
  echo "Log dir            : ${LOG_DIR}"
  echo "Auto download URL  : ${AUTO_DOWNLOAD_URL}"
  echo "Auto SHA256 set    : $([[ -n "${AUTO_DOWNLOAD_SHA256}" ]] && echo yes || echo no)"
  print_line
}

human_size() {
  local bytes="${1:-0}"
  awk -v b="$bytes" 'function human(x){s="B KB MB GB TB PB"; split(s,a," "); i=1; while(x>=1024 && i<6){x/=1024;i++} printf((i==1?"%.0f %s":"%.2f %s"),x,a[i])} BEGIN{human(b)}'
}

read_backup_info_value() {
  local file="$1"
  local key="$2"
  if [[ ! -f "$file" ]]; then
    echo ""
    return 0
  fi
  grep -E "^${key}=" "$file" | head -n1 | cut -d= -f2- || true
}

get_binary_version() {
  local bin="$1"
  if [ ! -x "$bin" ]; then
    echo "unavailable"
    return 0
  fi

  local out
  out="$($bin --version 2>/dev/null | head -n 1 || true)"
  if [ -n "$out" ]; then
    echo "$out"
  else
    echo "unknown"
  fi
}

version_from_filename() {
  local src="$1"
  local base cleaned ver
  base="$(basename "$src")"
  cleaned="$base"
  cleaned="${cleaned%.tar.gz}"
  cleaned="${cleaned%.tgz}"
  cleaned="${cleaned%.tar}"
  cleaned="${cleaned%.zip}"

  ver="$(echo "$cleaned" | grep -Eo '([0-9]+\.)+[0-9]+([.-](rc|beta|alpha)[0-9]*)?' | head -n1 || true)"
  if [[ -n "$ver" ]]; then
    echo "$ver"
    return 0
  fi

  ver="$(echo "$cleaned" | sed -E 's/[_-]+/ /g' | grep -Eo 'v?[0-9]+([[:space:]][0-9]+)+' | head -n1 | tr ' ' '.' | sed 's/^v//' || true)"
  if [[ -n "$ver" ]]; then
    echo "$ver"
    return 0
  fi

  echo "unknown"
}

get_current_version() {
  CURRENT_VERSION="$(get_binary_version "${DEFAULT_DAEMON}")"
}

check_service_and_process() {
  print_line
  info "Checking service and daemon process..."

  if systemctl status "${DEFAULT_SERVICE}.service" >/dev/null 2>&1; then
    echo "Service unit       : found (${DEFAULT_SERVICE}.service)"
    if systemctl is-active --quiet "${DEFAULT_SERVICE}"; then
      echo "Service status     : active"
    else
      echo "Service status     : not active"
    fi
    if systemctl is-enabled "${DEFAULT_SERVICE}" >/dev/null 2>&1; then
      echo "Service enabled    : yes"
    else
      echo "Service enabled    : no"
    fi
  else
    warn "Service unit ${DEFAULT_SERVICE}.service was not found."
  fi

  if pgrep -f "${DEFAULT_DAEMON}" >/dev/null 2>&1; then
    local proc_line pid cmd bin
    proc_line="$(pgrep -af "${DEFAULT_DAEMON}" | head -n1)"
    pid="${proc_line%% *}"
    cmd="${proc_line#* }"
    bin="${cmd%% *}"
    echo "Daemon process     : running"
    echo "Daemon PID         : ${pid}"
    echo "Daemon binary      : ${bin}"
  else
    echo "Daemon process     : not running"
  fi

  print_line
}

show_local_status() {
  print_line
  info "Checking local node status..."
  local blockcount="unknown"
  blockcount="$(run_cli getblockcount 2>/dev/null || echo "unavailable")"
  echo "Local block height : ${blockcount}"
  echo
  echo "masternode status:"
  run_cli masternode status 2>/dev/null || warn "Could not read masternode status."
  echo
  echo "mnsync status:"
  run_cli mnsync status 2>/dev/null || warn "Could not read mnsync status."
  print_line
}

ensure_daemon_running() {
  print_line
  info "Checking whether the daemon is already running..."

  local rpc_ok=1
  local service_active=1
  local proc_ok=1
  local service_exists=1

  if timeout 5 "${DEFAULT_CLI}" -datadir="${DEFAULT_DATA_DIR}" -conf="${DEFAULT_CONF_FILE}" getblockcount >/dev/null 2>&1; then
    rpc_ok=0
  fi

  if systemctl status "${DEFAULT_SERVICE}.service" >/dev/null 2>&1; then
    service_exists=0
    if systemctl is-active --quiet "${DEFAULT_SERVICE}"; then
      service_active=0
    fi
  fi

  if pgrep -f "${DEFAULT_DAEMON}" >/dev/null 2>&1; then
    proc_ok=0
  fi

  if [ "${rpc_ok}" -eq 0 ]; then
    success "Daemon is already running and RPC is responding."
    check_service_and_process
    return 0
  fi

  print_line
  echo "Startup check summary:"
  echo " - Service unit found : $([[ ${service_exists} -eq 0 ]] && echo yes || echo no)"
  echo " - Service active     : $([[ ${service_active} -eq 0 ]] && echo yes || echo no)"
  echo " - Daemon process     : $([[ ${proc_ok} -eq 0 ]] && echo yes || echo no)"
  echo " - RPC responding     : no"
  print_line

  warn "Daemon does not appear to be fully healthy or RPC is not responding."
}

verify_daemon_stopped() {
  local rpc_dead=1
  local proc_dead=1
  local service_inactive=1

  if ! pgrep -f "${DEFAULT_DAEMON}" >/dev/null 2>&1; then
    proc_dead=0
  fi

  if systemctl status "${DEFAULT_SERVICE}.service" >/dev/null 2>&1; then
    if ! systemctl is-active --quiet "${DEFAULT_SERVICE}"; then
      service_inactive=0
    fi
  else
    service_inactive=0
  fi

  if ! timeout 5 "${DEFAULT_CLI}" -datadir="${DEFAULT_DATA_DIR}" -conf="${DEFAULT_CONF_FILE}" getblockcount >/dev/null 2>&1; then
    rpc_dead=0
  fi

  print_line
  echo "Stop verification:"
  echo " - Process stopped : $([[ ${proc_dead} -eq 0 ]] && echo yes || echo no)"
  echo " - Service inactive: $([[ ${service_inactive} -eq 0 ]] && echo yes || echo no)"
  echo " - RPC unreachable : $([[ ${rpc_dead} -eq 0 ]] && echo yes || echo no)"
  print_line

  if [[ ${proc_dead} -eq 0 && ${service_inactive} -eq 0 && ${rpc_dead} -eq 0 ]]; then
    return 0
  fi
  return 1
}

ensure_clean_stop_with_retry() {
  local attempt=1
  local max_attempts=3
  local answer

  while (( attempt <= max_attempts )); do
    print_line
    info "Preparing clean stop (attempt ${attempt}/${max_attempts})..."

    # 1) First stop and deactivate service
    if systemctl status "${DEFAULT_SERVICE}.service" >/dev/null 2>&1; then
      info "Stopping service ${DEFAULT_SERVICE}..."
      systemctl stop "${DEFAULT_SERVICE}" >/dev/null 2>&1 || warn "systemctl stop returned non-zero."
      sleep 5

      info "Disabling service ${DEFAULT_SERVICE} (prevents auto-restart)..."
      if systemctl disable "${DEFAULT_SERVICE}" >/dev/null 2>&1; then
        SERVICE_WAS_DISABLED=1
        success "Service stopped and disabled."
      else
        warn "systemctl disable returned non-zero."
      fi
      sleep 3
    else
      warn "Service unit ${DEFAULT_SERVICE}.service not found during stop."
    fi

    # 2) If process is still running: RPC-stop, normal kill, hard kill
    if pgrep -f "${DEFAULT_DAEMON}" >/dev/null 2>&1; then
      info "Daemon process still running. Trying RPC stop..."
      run_cli stop >/dev/null 2>&1 || warn "RPC stop returned non-zero."
      sleep 10
      if verify_daemon_stopped; then
        success "Daemon confirmed stopped after RPC stop."
        return 0
      fi
    fi

    if pgrep -f "${DEFAULT_DAEMON}" >/dev/null 2>&1; then
      warn "Daemon still running after RPC stop. Trying normal kill..."
      pkill -f "${DEFAULT_DAEMON}" || warn "pkill returned non-zero."
      sleep 5
      if verify_daemon_stopped; then
        success "Daemon confirmed stopped after normal kill."
        return 0
      fi
    fi

    if pgrep -f "${DEFAULT_DAEMON}" >/dev/null 2>&1; then
      warn "Daemon still running after normal kill. Trying hard kill (SIGKILL)..."
      pkill -9 -f "${DEFAULT_DAEMON}" || warn "pkill -9 returned non-zero."
      sleep 3
    fi

    show_stop_summary

    if verify_daemon_stopped; then
      success "Daemon and service are fully stopped and disabled."
      return 0
    fi

    error "Safe stopped state could NOT be confirmed on attempt ${attempt}."
    if (( attempt >= max_attempts )); then
      break
    fi

    read -r -p "Stop not confirmed. Retry stopping? [y/N]: " answer
    case "$answer" in
      y|Y|yes|YES)
        attempt=$((attempt + 1))
        ;;
      *)
        error "User chose to abort because stop could not be confirmed."
        return 1
        ;;
    esac
  done

  error "Daemon/service could not be stopped safely after ${max_attempts} attempts."
  error "Update/rollback/cleanup cannot continue safely."
  return 1
}

show_stop_summary() {
  print_line
  echo "Shutdown summary"
  echo "----------------"

  if systemctl status "${DEFAULT_SERVICE}.service" >/dev/null 2>&1; then
    if systemctl is-active --quiet "${DEFAULT_SERVICE}"; then
      echo "Service state : active"
    else
      echo "Service state : inactive"
    fi

    if systemctl is-enabled "${DEFAULT_SERVICE}" >/dev/null 2>&1; then
      echo "Service boot  : enabled"
    else
      echo "Service boot  : disabled or masked"
    fi
  else
    echo "Service state : service unit not loaded"
  fi

  if pgrep -af "${DEFAULT_DAEMON}" >/dev/null 2>&1; then
    echo "Process state : running"
    pgrep -af "${DEFAULT_DAEMON}"
  else
    echo "Process state : not running"
  fi

  if timeout 5 "${DEFAULT_CLI}" -datadir="${DEFAULT_DATA_DIR}" -conf="${DEFAULT_CONF_FILE}" getblockcount >/dev/null 2>&1; then
    echo "RPC state     : responding"
  else
    echo "RPC state     : not responding"
  fi

  print_line
}

stop_daemon_cautious() {
  print_line
  warn "The script will now ensure that daemon and service are fully stopped."
  warn "This is required for update or rollback."

  ensure_clean_stop_with_retry
}

restore_service_if_needed() {
  print_line
  info "The script will now ensure that the service is enabled and started."

  if ! systemctl list-unit-files | awk '{print $1}' | grep -qx "${DEFAULT_SERVICE}.service"; then
    error "Service unit ${DEFAULT_SERVICE}.service not found during restore."
    return 1
  fi

  info "Unmasking service (if masked)..."
  systemctl unmask "${DEFAULT_SERVICE}" >/dev/null 2>&1 || true

  info "Enabling service..."
  if ! systemctl enable "${DEFAULT_SERVICE}" >/dev/null 2>&1; then
    error "systemctl enable did not succeed."
    return 1
  fi
  success "Service enabled."
  sleep 2

  info "Starting service..."
  if ! systemctl start "${DEFAULT_SERVICE}" >/dev/null 2>&1; then
    error "systemctl start did not succeed."
    echo "Check: systemctl status ${DEFAULT_SERVICE}"
    echo "   and: journalctl -u ${DEFAULT_SERVICE} -n 50"
    return 1
  fi

  sleep 5
  if ! systemctl is-active --quiet "${DEFAULT_SERVICE}"; then
    error "Service is not active after start."
    return 1
  fi
  success "Daemon appears to be running after service restore."

  if ! timeout 10 "${DEFAULT_CLI}" -datadir="${DEFAULT_DATA_DIR}" -conf="${DEFAULT_CONF_FILE}" getblockcount >/dev/null 2>&1; then
    error "RPC is not responding after service restore."
    return 1
  fi
  success "RPC is responding after service restore."

  check_service_and_process
  return 0
}

show_post_start_checks() {
  print_line
  info "Checking whether the masternode is running cleanly after start..."
  check_service_and_process

  local attempts=0
  local max_attempts=3
  local sleep_between=10
  local rpc_ok=1

  while (( attempts < max_attempts )); do
    if timeout 10 run_cli getblockcount >/dev/null 2>&1; then
      rpc_ok=0
      break
    fi
    attempts=$((attempts + 1))
    info "RPC not yet responding, waiting ${sleep_between}s... (attempt ${attempts}/${max_attempts})"
    sleep "${sleep_between}"
  done

  if [[ ${rpc_ok} -eq 0 ]]; then
    success "RPC is responding."
    echo "Block height       : $(run_cli getblockcount 2>/dev/null || echo unknown)"
  else
    error "RPC is not responding after ${max_attempts} attempts."
  fi

  echo
  echo "getnetworkinfo:"
  run_cli getnetworkinfo 2>/dev/null || warn "getnetworkinfo failed."
  echo
  echo "mnsync status:"
  run_cli mnsync status 2>/dev/null || warn "mnsync status failed."
  echo
  echo "masternode status:"
  run_cli masternode status 2>/dev/null || warn "masternode status failed."
  print_line
}

choose_action() {
  local choice
  print_line
  echo "Select action:"
  echo "  1) Binary update"
  echo "  2) Binary rollback"
  echo "  3) Cleanup existing backups"
  print_line

  while true; do
    read -r -p "Enter 1, 2 or 3: " choice
    case "$choice" in
      1)
        SELECTED_ACTION="update"
        return 0
        ;;
      2)
        SELECTED_ACTION="rollback"
        return 0
        ;;
      3)
        SELECTED_ACTION="cleanup"
        return 0
        ;;
      *)
        warn "Invalid selection. Please enter 1, 2 or 3."
        ;;
    esac
  done
}

choose_update_source_mode() {
  local choice
  print_line
  echo "Select update source:"
  echo "  1) Automatic update using predefined default URL"
  echo "  2) Enter download URL or local archive path manually"
  print_line

  while true; do
    read -r -p "Enter 1 or 2: " choice
    case "$choice" in
      1)
        UPDATE_SOURCE_MODE="auto"
        SELECTED_SOURCE_TYPE="url"
        SELECTED_SOURCE="${AUTO_DOWNLOAD_URL}"
        SELECTED_SHA256="${AUTO_DOWNLOAD_SHA256}"
        return 0
        ;;
      2)
        UPDATE_SOURCE_MODE="manual"
        return 0
        ;;
      *)
        warn "Invalid selection. Please enter 1 or 2."
        ;;
    esac
  done
}

prompt_manual_source() {
  local input
  print_line
  echo "Enter manual source"
  echo "- URL (http/https) or"
  echo "- local archive file path"
  print_line

  while true; do
    read -r -p "Source: " input
    input="$(trim "${input:-}")"

    if [[ -z "$input" ]]; then
      warn "Please enter a source."
      continue
    fi

    SELECTED_SOURCE="$input"
    if [[ "$input" =~ ^https?:// ]]; then
      SELECTED_SOURCE_TYPE="url"
    else
      SELECTED_SOURCE_TYPE="file"
    fi
    break
  done

  if ask_yes_no "Do you want to use an optional SHA256 checksum in manual mode?"; then
    read -r -p "Enter SHA256 (optional, leave empty to skip): " input
    input="$(trim "${input:-}")"
    if [[ -n "$input" ]]; then
      SELECTED_SHA256="$input"
      info "Manual SHA256 checksum will be used."
    else
      warn "No SHA256 entered. Continuing without checksum verification."
    fi
  else
    warn "Manual mode without SHA256 checksum selected."
  fi
}

validate_update_selection() {
  if [[ "${UPDATE_SOURCE_MODE}" == "auto" ]]; then
    if [[ -z "${AUTO_DOWNLOAD_URL}" ]]; then
      error "AUTO_DOWNLOAD_URL is empty."
      exit 1
    fi
    if [[ -z "${AUTO_DOWNLOAD_SHA256}" ]]; then
      error "AUTO_DOWNLOAD_SHA256 is empty. SHA256 is required for automatic updates."
      exit 1
    fi
  fi

  if [[ "${SELECTED_SOURCE_TYPE}" == "file" && ! -f "${SELECTED_SOURCE}" ]]; then
    error "Local file not found: ${SELECTED_SOURCE}"
    exit 1
  fi
}

show_plan_summary() {
  print_line
  echo "Planned action:"
  echo "Action            : ${SELECTED_ACTION}"
  echo "Current version   : ${CURRENT_VERSION}"
  if [[ "${SELECTED_ACTION}" == "update" ]]; then
    echo "Source mode       : ${UPDATE_SOURCE_MODE}"
    echo "Source type       : ${SELECTED_SOURCE_TYPE}"
    echo "Source            : ${SELECTED_SOURCE}"
    echo "SHA256 enabled    : $([[ -n "${SELECTED_SHA256}" ]] && echo yes || echo no)"
    echo "Version from name : ${TARGET_VERSION_FROM_FILENAME}"
  elif [[ "${SELECTED_ACTION}" == "rollback" ]]; then
    echo "Rollback backup   : ${LATEST_BACKUP_DIR}"
    echo "Rollback source   : ${ROLLBACK_SOURCE}"
    echo "Rollback action   : ${ROLLBACK_ACTION}"
  fi
  echo "Install target    : ${DEFAULT_INSTALL_DIR}"
  echo "Backup base       : ${BACKUP_BASE_DIR}"
  echo "Service           : ${DEFAULT_SERVICE}"
  echo "Log file          : ${LOG_FILE}"
  print_line
}

fetch_archive() {
  rm -rf "${WORK_DIR:?}/download" "${WORK_DIR:?}/extract"
  mkdir -p "${WORK_DIR}/download" "${WORK_DIR}/extract"
  SELECTED_ARCHIVE_PATH="${WORK_DIR}/download/$(basename "${SELECTED_SOURCE}")"

  if [[ "${SELECTED_SOURCE_TYPE}" == "url" ]]; then
    info "Downloading archive..."
    if command -v curl >/dev/null 2>&1; then
      if [[ "${DRY_RUN}" -eq 1 ]]; then
        info "[DRY-RUN] curl -L --fail --retry 3 -o ${SELECTED_ARCHIVE_PATH} ${SELECTED_SOURCE}"
      else
        curl -L --fail --retry 3 -o "${SELECTED_ARCHIVE_PATH}" "${SELECTED_SOURCE}"
      fi
    else
      if [[ "${DRY_RUN}" -eq 1 ]]; then
        info "[DRY-RUN] wget -O ${SELECTED_ARCHIVE_PATH} ${SELECTED_SOURCE}"
      else
        wget -O "${SELECTED_ARCHIVE_PATH}" "${SELECTED_SOURCE}"
      fi
    fi
  else
    info "Copying local archive into work directory..."
    run_cmd cp -f "${SELECTED_SOURCE}" "${SELECTED_ARCHIVE_PATH}"
  fi

  if [[ ! -s "${SELECTED_ARCHIVE_PATH}" ]]; then
    error "Archive was not correctly provided: ${SELECTED_ARCHIVE_PATH}"
    exit 1
  fi

  TARGET_VERSION_FROM_FILENAME="$(version_from_filename "${SELECTED_SOURCE}")"
  info "Version detected from archive name: ${TARGET_VERSION_FROM_FILENAME}"
  info "Archive details:"
  ls -lh "${SELECTED_ARCHIVE_PATH}"
  file "${SELECTED_ARCHIVE_PATH}" || true
}

verify_sha256_if_requested() {
  if [[ -z "${SELECTED_SHA256}" ]]; then
    warn "No SHA256 verification active."
    return 0
  fi

  local actual expected
  actual="$(sha256sum "${SELECTED_ARCHIVE_PATH}" | awk '{print $1}' | tr 'A-F' 'a-f')"
  expected="$(echo "${SELECTED_SHA256}" | tr 'A-F' 'a-f')"

  echo "Expected SHA256 : ${expected}"
  echo "Actual SHA256   : ${actual}"

  if [[ "${actual}" != "${expected}" ]]; then
    error "SHA256 verification failed. Aborting."
    exit 1
  fi

  success "SHA256 verification successful."
}

extract_archive() {
  info "Extracting archive..."

  if [[ "${DRY_RUN}" -eq 1 ]]; then
    info "[DRY-RUN] Extraction would be performed now: ${SELECTED_ARCHIVE_PATH}"
    export EXTRACTED_DAEMON="${WORK_DIR}/extract/defcond"
    export EXTRACTED_CLI="${WORK_DIR}/extract/defcon-cli"
    TARGET_VERSION="${TARGET_VERSION_FROM_FILENAME}"
    return 0
  fi

  case "${SELECTED_ARCHIVE_PATH}" in
    *.tar.gz|*.tgz)
      tar -xzf "${SELECTED_ARCHIVE_PATH}" -C "${WORK_DIR}/extract"
      ;;
    *.tar)
      tar -xf "${SELECTED_ARCHIVE_PATH}" -C "${WORK_DIR}/extract"
      ;;
    *)
      error "Unknown archive format: ${SELECTED_ARCHIVE_PATH}"
      exit 1
      ;;
  esac

  local daemon_found cli_found
  daemon_found="$(find "${WORK_DIR}/extract" -type f -name 'defcond' | head -n 1 || true)"
  cli_found="$(find "${WORK_DIR}/extract" -type f -name 'defcon-cli' | head -n 1 || true)"

  if [[ -z "$daemon_found" || -z "$cli_found" ]]; then
    error "Archive does not contain defcond and/or defcon-cli."
    exit 1
  fi

  chmod +x "$daemon_found" "$cli_found"
  validate_archive_contents
  TARGET_VERSION="$(get_binary_version "$daemon_found")"
  if [[ "$TARGET_VERSION" == "unknown" || "$TARGET_VERSION" == "unavailable" ]] && [[ "$TARGET_VERSION_FROM_FILENAME" != "unknown" ]]; then
    TARGET_VERSION="${TARGET_VERSION_FROM_FILENAME}"
  fi
  export EXTRACTED_DAEMON="$daemon_found"
  export EXTRACTED_CLI="$cli_found"

  success "Archive was extracted successfully."
  echo "Detected new version: ${TARGET_VERSION}"
}

create_binary_backup() {
  local ts backup_dir
  ts="$(date +%Y%m%d-%H%M%S)"
  backup_dir="${BACKUP_BASE_DIR}/${ts}"
  mkdir -p "${backup_dir}"

  check_free_space_or_exit "${BACKUP_BASE_DIR}" "${MIN_FREE_MB_BACKUP}" "backup"
  run_cmd cp -a "${DEFAULT_DAEMON}" "${backup_dir}/defcond"
  run_cmd cp -a "${DEFAULT_CLI}" "${backup_dir}/defcon-cli"

  cat > "${backup_dir}/backup-info.txt" <<INFOEOF
Timestamp=${ts}
Action=${SELECTED_ACTION}
CurrentVersion=${CURRENT_VERSION}
SourceMode=${UPDATE_SOURCE_MODE}
Source=${SELECTED_SOURCE}
SourceType=${SELECTED_SOURCE_TYPE}
TargetVersion=${TARGET_VERSION}
TargetVersionFromFilename=${TARGET_VERSION_FROM_FILENAME}
DaemonPath=${DEFAULT_DAEMON}
CliPath=${DEFAULT_CLI}
LogFile=${LOG_FILE}
INFOEOF

  ln -sfn "${backup_dir}" "${BACKUP_BASE_DIR}/latest"
  LATEST_BACKUP_DIR="${backup_dir}"
  success "Backup of current binaries created: ${backup_dir}"
}

install_new_binaries() {
  info "Installing new binaries..."
  run_cmd cp -f "${EXTRACTED_DAEMON}" "${DEFAULT_DAEMON}"
  run_cmd cp -f "${EXTRACTED_CLI}" "${DEFAULT_CLI}"
  run_cmd chmod 755 "${DEFAULT_DAEMON}" "${DEFAULT_CLI}"

  if [[ ! -x "${DEFAULT_DAEMON}" || ! -x "${DEFAULT_CLI}" ]]; then
    error "New binaries were not installed correctly."
    exit 1
  fi

  success "New binaries installed successfully."
  echo "Installed version: $(get_binary_version "${DEFAULT_DAEMON}")"
}

load_backups() {
  BACKUP_DIRS=()
  BACKUP_DISPLAY_LINES=()
  BACKUP_VERSIONS=()
  BACKUP_TIMESTAMPS=()
  BACKUP_SIZES=()
  BACKUP_SOURCES=()
  BACKUP_ACTIONS=()

  while IFS= read -r dir; do
    [[ -n "$dir" ]] || continue
    BACKUP_DIRS+=("$dir")
  done < <(find "${BACKUP_BASE_DIR}" -mindepth 1 -maxdepth 1 -type d | sort)

  if [[ "${#BACKUP_DIRS[@]}" -eq 0 ]]; then
    warn "No backup directories found in ${BACKUP_BASE_DIR}."
    return 1
  fi

  local dir info_file ts ver size_b size_h source action idx target_ver
  for idx in "${!BACKUP_DIRS[@]}"; do
    dir="${BACKUP_DIRS[$idx]}"
    info_file="${dir}/backup-info.txt"
    ts="$(basename "$dir")"
    ver="unknown"
    source="unknown"
    action="unknown"
    target_ver="unknown"

    if [[ -f "$info_file" ]]; then
      ts="$(read_backup_info_value "$info_file" "Timestamp")"
      [[ -n "$ts" ]] || ts="$(basename "$dir")"
      ver="$(read_backup_info_value "$info_file" "CurrentVersion")"
      [[ -n "$ver" ]] || ver="unknown"
      source="$(read_backup_info_value "$info_file" "Source")"
      [[ -n "$source" ]] || source="unknown"
      action="$(read_backup_info_value "$info_file" "Action")"
      [[ -n "$action" ]] || action="unknown"
      target_ver="$(read_backup_info_value "$info_file" "TargetVersion")"
      [[ -n "$target_ver" ]] || target_ver="unknown"
    fi

    size_b="$(du -sb "$dir" 2>/dev/null | awk '{print $1}')"
    size_h="$(human_size "$size_b")"
    BACKUP_TIMESTAMPS+=("$ts")
    BACKUP_VERSIONS+=("$ver")
    BACKUP_SIZES+=("$size_b")
    BACKUP_SOURCES+=("$source")
    BACKUP_ACTIONS+=("$action")
    BACKUP_DISPLAY_LINES+=("[$((idx + 1))] Timestamp: ${ts} | Version: ${ver} | Target: ${target_ver} | Action: ${action} | Size: ${size_h} | Source: ${source}")
  done

  return 0
}

show_backup_list() {
  if ! load_backups; then
    return 1
  fi

  print_line
  echo "Existing backups:"
  local line
  for line in "${BACKUP_DISPLAY_LINES[@]}"; do
    echo "${line}"
  done
  print_line
  return 0
}

select_backup_for_rollback() {
  show_backup_list || exit 1

  local choice index selected
  while true; do
    read -r -p "Number of the backup to use for rollback: " choice
    if ! is_number "$choice"; then
      warn "Please enter a valid number."
      continue
    fi
    index=$((choice - 1))
    if (( index < 0 || index >= ${#BACKUP_DIRS[@]} )); then
      warn "Number is out of valid range."
      continue
    fi
    selected="${BACKUP_DIRS[$index]}"
    LATEST_BACKUP_DIR="$selected"
    ROLLBACK_SOURCE="${BACKUP_SOURCES[$index]}"
    ROLLBACK_ACTION="${BACKUP_ACTIONS[$index]}"
    print_line
    echo "Selected rollback backup:"
    echo "Path             : ${LATEST_BACKUP_DIR}"
    echo "Timestamp        : ${BACKUP_TIMESTAMPS[$index]}"
    echo "Version          : ${BACKUP_VERSIONS[$index]}"
    echo "Size             : $(human_size "${BACKUP_SIZES[$index]}")"
    echo "Source           : ${ROLLBACK_SOURCE}"
    echo "Action           : ${ROLLBACK_ACTION}"
    print_line
    return 0
  done
}

sum_selected_backup_bytes() {
  local total=0 dir bytes
  for dir in "$@"; do
    bytes="$(du -sb "$dir" 2>/dev/null | awk '{print $1}')"
    total=$((total + bytes))
  done
  echo "$total"
}

cleanup_selected_backups() {
  local dirs_to_delete=("$@")
  if [[ "${#dirs_to_delete[@]}" -eq 0 ]]; then
    warn "No backups selected for deletion."
    return 0
  fi

  local total_bytes deleted_count=0 dir
  total_bytes="$(sum_selected_backup_bytes "${dirs_to_delete[@]}")"

  print_line
  echo "The following backups will be deleted:"
  for dir in "${dirs_to_delete[@]}"; do
    echo " - ${dir}"
  done
  echo "Count             : ${#dirs_to_delete[@]}"
  echo "Space to free     : $(human_size "$total_bytes")"
  print_line

  if ! ask_yes_no "Proceed with deletion now?"; then
    warn "Deletion was cancelled."
    return 0
  fi

  for dir in "${dirs_to_delete[@]}"; do
    if rm -rf "$dir"; then
      success "Deleted: ${dir}"
      deleted_count=$((deleted_count + 1))
    else
      error "Could not delete: ${dir}"
    fi
  done

  if [[ -L "${BACKUP_BASE_DIR}/latest" ]]; then
    local latest_target
    latest_target="$(readlink -f "${BACKUP_BASE_DIR}/latest" 2>/dev/null || true)"
    if [[ -n "$latest_target" && ! -d "$latest_target" ]]; then
      rm -f "${BACKUP_BASE_DIR}/latest" >/dev/null 2>&1 || true
      warn "Dangling latest symlink was removed."
    fi
  fi

  print_line
  success "Backup cleanup completed."
  echo "Deleted backups    : ${deleted_count}"
  echo "Freed disk space   : $(human_size "$total_bytes")"
  print_line
}

cleanup_all_backups() {
  show_backup_list || exit 1
  cleanup_selected_backups "${BACKUP_DIRS[@]}"
}

cleanup_keep_last_n_backups() {
  show_backup_list || exit 1

  while true; do
    read -r -p "How many newest backups should be kept? " KEEP_COUNT
    KEEP_COUNT="$(trim "${KEEP_COUNT:-}")"
    if ! is_number "$KEEP_COUNT"; then
      warn "Please enter a valid number."
      continue
    fi
    break
  done

  local total_count="${#BACKUP_DIRS[@]}"
  if (( KEEP_COUNT >= total_count )); then
    warn "There are only ${total_count} backups. Nothing will be deleted."
    return 0
  fi

  local delete_count=$((total_count - KEEP_COUNT))
  local dirs_to_delete=()
  local i
  for ((i=0; i<delete_count; i++)); do
    dirs_to_delete+=("${BACKUP_DIRS[$i]}")
  done

  cleanup_selected_backups "${dirs_to_delete[@]}"
}

cleanup_backups_older_than_days() {
  show_backup_list || exit 1

  while true; do
    read -r -p "Delete backups older than how many days? " DELETE_OLDER_THAN_DAYS
    DELETE_OLDER_THAN_DAYS="$(trim "${DELETE_OLDER_THAN_DAYS:-}")"
    if ! is_number "$DELETE_OLDER_THAN_DAYS"; then
      warn "Please enter a valid number."
      continue
    fi
    break
  done

  local dirs_to_delete=()
  local dir
  while IFS= read -r dir; do
    [[ -n "$dir" ]] && dirs_to_delete+=("$dir")
  done < <(find "${BACKUP_BASE_DIR}" -mindepth 1 -maxdepth 1 -type d -mtime +"${DELETE_OLDER_THAN_DAYS}" | sort)

  if [[ "${#dirs_to_delete[@]}" -eq 0 ]]; then
    warn "No backups found that are older than ${DELETE_OLDER_THAN_DAYS} days."
    return 0
  fi

  cleanup_selected_backups "${dirs_to_delete[@]}"
}

cleanup_menu() {
  local choice
  print_line
  echo "Backup cleanup options:"
  echo "  1) Delete all backups"
  echo "  2) Delete only older backups, keep last N"
  echo "  3) Delete only backups older than X days"
  echo "  4) Only list existing backups"
  print_line

  while true; do
    read -r -p "Enter 1, 2, 3 or 4: " choice
    case "$choice" in
      1)
        cleanup_all_backups
        return 0
        ;;
      2)
        cleanup_keep_last_n_backups
        return 0
        ;;
      3)
        cleanup_backups_older_than_days
        return 0
        ;;
      4)
        show_backup_list || true
        return 0
        ;;
      *)
        warn "Invalid selection. Please enter 1, 2, 3 or 4."
        ;;
    esac
  done
}

perform_rollback_install() {
  local rollback_daemon rollback_cli
  rollback_daemon="${LATEST_BACKUP_DIR}/defcond"
  rollback_cli="${LATEST_BACKUP_DIR}/defcon-cli"

  if [[ ! -x "${rollback_daemon}" || ! -x "${rollback_cli}" ]]; then
    error "Rollback binaries are missing or not executable in ${LATEST_BACKUP_DIR}"
    exit 1
  fi

  TARGET_VERSION="$(get_binary_version "${rollback_daemon}")"
  info "Restoring backup binaries..."
  run_cmd cp -f "${rollback_daemon}" "${DEFAULT_DAEMON}"
  run_cmd cp -f "${rollback_cli}" "${DEFAULT_CLI}"
  run_cmd chmod 755 "${DEFAULT_DAEMON}" "${DEFAULT_CLI}"

  success "Rollback binaries were installed successfully."
  echo "Rollback version   : $(get_binary_version "${DEFAULT_DAEMON}")"
}

run_update() {
  choose_update_source_mode
  if [[ "${UPDATE_SOURCE_MODE}" == "manual" ]]; then
    prompt_manual_source
  fi

  validate_update_selection
  TARGET_VERSION_FROM_FILENAME="$(version_from_filename "${SELECTED_SOURCE}")"
  show_plan_summary

  if ! ask_yes_no "Continue with the update?"; then
    warn "Update was cancelled by the user."
    exit 0
  fi

  check_free_space_or_exit "/tmp" "${MIN_FREE_MB_DOWNLOAD}" "download/extraction"
  fetch_archive
  verify_sha256_if_requested
  extract_archive
  create_binary_backup

  if ! ask_yes_no "Stop daemon now and install the update?"; then
    warn "Update was aborted before installation step."
    exit 0
  fi

  stop_daemon_cautious || exit 1
  install_new_binaries

  if systemctl status "${DEFAULT_SERVICE}.service" >/dev/null 2>&1; then
    systemctl daemon-reload >/dev/null 2>&1 || true
  fi

  success "Update installed successfully."

  restore_service_if_needed || exit 1
  show_post_start_checks
}

run_rollback() {
  select_backup_for_rollback
  show_plan_summary

  if ! ask_yes_no "Proceed with rollback using the selected backup?"; then
    warn "Rollback was cancelled by the user."
    exit 0
  fi

  stop_daemon_cautious || exit 1
  perform_rollback_install

  if systemctl status "${DEFAULT_SERVICE}.service" >/dev/null 2>&1; then
    systemctl daemon-reload >/dev/null 2>&1 || true
  fi

  success "Rollback installed successfully."

  restore_service_if_needed || exit 1
  show_post_start_checks
}

run_cleanup() {
  cleanup_menu
}

main() {
  parse_args "$@"
  trap on_exit EXIT
  check_root
  prepare_directories
  setup_logging
  show_intro
  check_conf_file
  check_binaries
  show_defaults
  get_current_version
  ensure_daemon_running
  choose_action

  case "${SELECTED_ACTION}" in
    update)
      run_update
      ;;
    rollback)
      run_rollback
      ;;
    cleanup)
      run_cleanup
      ;;
    *)
      error "Unknown action."
      exit 1
      ;;
  esac

  print_line
  echo "Script run completed."
  echo "Please continue monitoring the node."
  echo "Log file: ${LOG_FILE}"
  print_line
}

main "$@"
